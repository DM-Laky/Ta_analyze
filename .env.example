# ─────────────────────────────────────────
# APEX Trading Terminal — Environment Vars
# Copy to .env.local for local dev
# Set these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────

# Binance Futures API
# Create at: binance.com → Profile → API Management
# Permissions: Read Info + Futures Trading
# IMPORTANT: Whitelist your Vercel server IP shown on the dashboard
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Google Gemini API
# Create at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Vercel KV Database
# Auto-populated when you create a KV store in Vercel Dashboard
# Dashboard → Storage → Create KV Database → Connect to project
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here

# Account Settings
ACCOUNT_SIZE=100
MAX_MARGIN_PER_TRADE=6
